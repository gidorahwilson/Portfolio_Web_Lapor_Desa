<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Register Admin</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Segoe UI',sans-serif;
}

body{
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    background:linear-gradient(135deg,#4f46e5,#7c3aed);
}

/* CARD */
.card{
    width:380px;
    background:#fff;
    padding:35px;
    border-radius:14px;
    box-shadow:0 20px 50px rgba(0,0,0,.25);
    animation:fadeIn .6s ease;
}

@keyframes fadeIn{
    from{transform:translateY(20px);opacity:0}
    to{transform:translateY(0);opacity:1}
}

h2{
    text-align:center;
    margin-bottom:25px;
    color:#334155;
}

/* INPUT */
.form-group{
    margin-bottom:15px;
}

label{
    display:block;
    margin-bottom:6px;
    font-size:13px;
    color:#475569;
}

input{
    width:100%;
    padding:12px;
    border:1px solid #cbd5e1;
    border-radius:8px;
    outline:none;
    transition:.2s;
}

input:focus{
    border-color:#4f46e5;
    box-shadow:0 0 6px rgba(79,70,229,.4);
}

/* BUTTON */
button{
    width:100%;
    padding:12px;
    border:none;
    border-radius:8px;
    background:#4f46e5;
    color:#fff;
    font-size:15px;
    cursor:pointer;
    margin-top:10px;
    transition:.2s;
}

button:hover{
    background:#4338ca;
}

/* FOOTER LINK */
.footer{
    text-align:center;
    margin-top:15px;
    font-size:13px;
}

.footer a{
    color:#4f46e5;
    text-decoration:none;
}

.footer a:hover{
    text-decoration:underline;
}

/* SMALL TEXT */
.small{
    font-size:11px;
    color:#94a3b8;
    margin-top:5px;
}
</style>

</head>
<body>

<div class="card">

    <h2>Register Admin</h2>

    <form action="/regis-%7C-admin" method="POST">

        <div class="form-group">
            <label>Username</label>
            <input type="text" name="username" placeholder="Masukkan username" required>
        </div>

        <div class="form-group">
            <label>Password</label>
            <input type="password" name="password" placeholder="••••••••" required>
        </div>

        <div class="form-group">
            <label>Konfirmasi Password</label>
            <input type="password" name="confirm_password" placeholder="••••••••" required>
        </div>

        <button type="submit">Daftar Admin</button>

    </form>

    <div class="footer">
        Sudah punya akun? <a href="/AdminPengelola">Login</a>
        <div class="small">Sistem Admin Lapor Desa</div>
    </div>

</div>

</body>
</html>
