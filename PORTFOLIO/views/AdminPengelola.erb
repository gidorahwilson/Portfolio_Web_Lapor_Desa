<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Login Admin</title>

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:'Segoe UI',sans-serif}

body{
    height:100vh;
    background:radial-gradient(circle at top left,#7c3aed,#4f46e5,#1e1b4b);
    display:flex;
    justify-content:center;
    align-items:center;
    overflow:hidden;
    color:#fff;
}

/* Glow background */
body::before{
    content:'';
    position:absolute;
    width:600px;height:600px;
    background:rgba(255,255,255,0.05);
    filter:blur(120px);
    border-radius:50%;
    top:-100px;left:-100px;
}

/* Card */
.card{
    position:relative;
    width:420px;
    background:rgba(255,255,255,0.08);
    backdrop-filter:blur(20px);
    border:1px solid rgba(255,255,255,0.15);
    border-radius:18px;
    padding:50px 40px;
    box-shadow:0 25px 60px rgba(0,0,0,.4);
}

.card h2{
    text-align:center;
    margin-bottom:10px;
    letter-spacing:1px;
}

.card p{
    text-align:center;
    font-size:14px;
    color:#cbd5e1;
    margin-bottom:30px;
}

/* Form */
.form-group{margin-bottom:18px}
.form-group label{
    display:block;
    margin-bottom:6px;
    font-weight:600;
    font-size:14px;
}
.form-group input{
    width:100%;
    padding:12px;
    border-radius:8px;
    border:none;
    outline:none;
    font-size:14px;
}

/* Button */
.btn{
    width:100%;
    padding:14px;
    margin-top:10px;
    border:none;
    border-radius:8px;
    background:#fff;
    color:#4f46e5;
    font-weight:700;
    cursor:pointer;
    transition:.3s;
}
.btn:hover{
    background:#e0e7ff;
}

/* Footer */
.footer{
    text-align:center;
    margin-top:18px;
    font-size:12px;
    color:#cbd5e1;
}
</style>
</head>
<body>

<div class="card">
    <h2>Admin Panel Login</h2>
    <p>Sistem Pengaduan Online Masyarakat Desa</p>

    <form action="/admin/login" method="POST">
        <div class="form-group">
            <label>Username Admin</label>
            <input type="text" name="username" required>
        </div>

        <div class="form-group">
            <label>Password</label>
            <input type="password" name="password" required>
        </div>

        <button class="btn">Masuk ke Dashboard</button>
    </form>

    <div class="footer">
        Akses terbatas hanya untuk pengelola sistem
    </div>
</div>

</body>
</html>
